{
    // C++ with Clangd
    "C_Cpp.intelliSenseEngine": "disabled",
    "editor.defaultFormatter": null,
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnSave": true
    },
    "clangd.arguments": [
        "-j=8",
        "--clang-tidy",
        "--all-scopes-completion",
        "--completion-style=bundled",
        "--header-insertion=iwyu",
        "--header-insertion-decorators",
        "--compile-commands-dir=${workspaceFolder}/.artifacts/.build_MessageQueue_Debug",
    ],
    // C++ TestMake
    "testMate.cpp.debug.configTemplate": "name:(gdb) debug unit-test",
    "testMate.cpp.test.advancedExecutables": [
        {
            "pattern": "**/.build_MessageQueue_Debug/*Tests",
            "cwd": "${workspaceFolder}/.artifacts/.build_MessageQueue_Debug",
        }
    ],
    // Spell Checker
    "cSpell.words": [
        "amqp",
        "amqpcpp",
        "AUTOMOC",
        "AUTORCC",
        "autoreload",
        "AUTOUIC",
        "cmaketoolchain",
        "commandscript",
        "conanfile",
        "conanprofile",
        "cppstd",
        "DCMAKE",
        "endforeach",
        "endfunction",
        "gmock",
        "INVOKABLE",
        "libbz",
        "libcxx",
        "libdbus",
        "libevent",
        "libfontconfig",
        "libfreetype",
        "libqt",
        "libstdc",
        "libwayland",
        "libxkbcommon",
        "pthreads",
        "qtdeclarative",
        "qtquick",
        "qtshadertools",
        "venv",
        "xkbcommon"
    ],
}